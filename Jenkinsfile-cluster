pipeline {
    agent any

    environment {
        my_aws_access= credentials('aws-access')
    }

    tools {
        terraform 'tf-install'
    }
    
    stages {
        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }
         stage('Terraform fmt-validate') {
            steps {
                sh '''
                terraform fmt
                terraform validate
                '''
            }
        }
         stage('Terraform plan') {
            steps {
                sh 'terraform plan'
            }
        }
         stage('Terraform APPLY') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}
